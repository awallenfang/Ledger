@page "/leaderboard/{guild_id}"
@page "/leaderboard/{guild_id}/{page:int}"
@attribute [ExcludeFromInteractiveRouting]
@using Fluxify.Rest
@using Ledger.Services
@using Database
@using Database.Services
@using Microsoft.AspNetCore.Mvc.ModelBinding
@inject LeaderboardDbService db
@inject BotRestClient rest
<h1>Leaderboard</h1>
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

@using Dashboard.Models

<PageTitle>Guild Leaderboard</PageTitle>
@if (users == null)
{
    <p><em>There seems to be no users with experience on this server...</em></p>
}
else
{
    <table class="table w-100 align-middle text-center">
        <thead>
            <tr>
                <td>Position</td>
                <td>Name</td>
                <td>Level</td>
                <td>Exp</td>
                <td></td>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>#@user.Position</td>
                    <td>@user.Name</td>
                    <td>@user.CurrentLevel</td>
                    <td>@user.Exp</td>
                    <td>
                        <div
                            style="width: 10rem; background: var(--bs-body-bg-alt); border-radius: 4px; vertical-align: middle">
                            <div style="width: @( (user.Exp % 100) / 2.0 )%; 
                                background: var(--bs-primary); 
                                height: 10px; 
                                border-radius: 4px;">
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex justify-content-center gap-2 mt-3">
    @if (page > 0)
    {
        <a href="/leaderboard/@guild_id/@(page - 1)" class="btn btn-secondary">Previous</a>
    }
    <span class="btn disabled">Page @(page + 1)</span>
    @if (HasNextPage)
    {
        <a href="/leaderboard/@guild_id/@(page + 1)" class="btn btn-secondary">Next</a>
    }
</div>

@code {
    private User[]? users;
    [Parameter] public string? guild_id { get; set; }
    [Parameter] public int page { get; set; } = 0;

    private const int PageSize = 50;
    private bool HasNextPage = false;
    protected override async Task OnInitializedAsync()
    {

        var db_users = await db.GetGuildLeaderboard(Convert.ToInt64(guild_id), page, PageSize, PageSize + 1) ?? new();
        HasNextPage = db_users.Count > PageSize;
        db_users = db_users.Take(PageSize).ToList();
        var actual_users = new List<User>();
        var idx = (page * PageSize) + 1;
        foreach (var user in db_users)
        {
            var fluxerUser = await rest.Users[user.User.UserId].GetAsync();
            if (fluxerUser is not null)
            {
                actual_users.Add(
                    new User
                    {
                        Name = fluxerUser.Username,
                        Exp = user.Exp,
                        CurrentLevel = user.Level,
                        Position = idx,
                    }
                );

            }
            idx += 1;
        }
        users = actual_users.ToArray();

    }

    private class User
    {
        public string Name { get; set; }
        public int Exp { get; set; }
        public int CurrentLevel { get; set; }
        public int Position { get; set; }
    }
}