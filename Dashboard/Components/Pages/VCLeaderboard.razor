@page "/leaderboard/vc/{guild_id}"
@page "/leaderboard/vc/{guild_id}/{page:int}"
@attribute [ExcludeFromInteractiveRouting]
@using Fluxify.Rest
@using Ledger.Services
@using Database
@using Database.Services
@using Microsoft.AspNetCore.Mvc.ModelBinding
@inject GuildDbService guild_db
@inject LeaderboardDbService db
@inject BotRestClient rest
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

@using Dashboard.Models

<PageTitle>Guild VC Leaderboard</PageTitle>
<h1>VC Leaderboard</h1>

<div class="d-flex justify-content-center gap-2 mt-3">
    <a href="/leaderboard/@guild_id" class="btn btn-primary text-white">Go to chat Leaderboard</a>
</div>

@if (users == null)
{
    <p><em>There seems to be no users with experience on this server...</em></p>
}
else
{
    <table class="table w-100 align-middle text-center">
        <thead>
            <tr>
                <td>Position</td>
                <td>Name</td>
                <td>Level</td>
                <td>Exp</td>
                <td></td>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                <tr>
                    <td>#@user.Position</td>
                    <td>@user.Name</td>
                    <td>@user.CurrentLevel</td>
                    <td>@user.Exp</td>
                    <td class="d-none d-md-table-cell">
                        <div style="width: 10rem; background: var(--bs-body-bg-alt); border-radius: 4px;">
                            <div
                                style="width: @user.BarPercentage%; background: var(--bs-primary); height: 10px; border-radius: 4px;">
                            </div>
                        </div>
                    </td>
                </tr>
                <tr class="d-table-row d-md-none">
                    <td colspan="4" class="pt-2">
                        <div style="width: 100%; background: var(--bs-body-bg-alt); border-radius: 4px;">
                            <div
                                style="width: @user.BarPercentage%; background: var(--bs-primary); height: 10px; border-radius: 4px;">
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex justify-content-center gap-2 mt-3">
    @if (page > 0)
    {
        <a href="/leaderboard/@guild_id/@(page - 1)" class="btn btn-primary text-white">Previous</a>
    }
    <span class="btn disabled">Page @(page + 1)</span>
    @if (HasNextPage)
    {
        <a href="/leaderboard/@guild_id/@(page + 1)" class="btn btn-primary text-white">Next</a>
    }
</div>

@code {
    private User[]? users;
    [Parameter] public string? guild_id { get; set; }
    [Parameter] public int page { get; set; } = 0;

    private const int PageSize = 50;
    private bool HasNextPage = false;
    protected override async Task OnInitializedAsync()
    {

        var db_users = await db.GetGuildVCLeaderboard(Convert.ToInt64(guild_id), page, PageSize, PageSize + 1) ?? new();
        HasNextPage = db_users.Count > PageSize;
        db_users = db_users.Take(PageSize).ToList();
        var actual_users = new List<User>();
        var idx = (page * PageSize) + 1;
        var guild = await guild_db.GetOrCreateGuildAsync(long.Parse(guild_id!));
        var guildSettings = await db.GetOrCreateSettingsAsync(guild);
        foreach (var user in db_users)
        {
            var fluxerUser = await rest.Users[user.User.UserId].GetAsync();
            if (fluxerUser is not null)
            {
                var level = guildSettings.GetLevel(user.Exp);
                var bar_percentage = (float)(user.Exp - guildSettings.GetTotalXpForLevel(level)) / (float)(user.Exp + guildSettings.GetTotalXpForLevel(level + 1) - guildSettings.GetTotalXpForLevel(level));
                var url = $"https://fluxerusercontent.com/avatars/{user.User.UserId}/{fluxerUser.Avatar}.webp" ?? null;

                actual_users.Add(
                    new User
                    {
                        Name = fluxerUser.Username,
                        Exp = user.Exp,
                        CurrentLevel = level,
                        BarPercentage = (int)(bar_percentage * 100),
                        Position = idx,
                        AvatarURL = url
                    }
                );

            }
            idx += 1;
        }
        users = actual_users.ToArray();

    }

    private class User
    {
        public string Name { get; set; }
        public int Exp { get; set; }
        public int CurrentLevel { get; set; }
        public int BarPercentage { get; set; }
        public int Position { get; set; }
        public string? AvatarURL { get; set; }
    }
}