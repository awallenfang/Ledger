@page "/profile"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject LeaderboardDbService db
@inject GuildDbService guild_db
<PageTitle>Profile Settings</PageTitle>
<h3>Profile Settings</h3>
@* 
<p>Username: @User.FindFirstValue(ClaimTypes.Name)</p>
<p>Email: @User.FindFirstValue(ClaimTypes.Email)</p>
<p>Global name: @User.FindFirstValue("fluxer:global_name")</p>

<a href="/logout" class="btn btn-secondary">Logout</a> *@

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private ClaimsPrincipal User { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        
        if (AuthenticationStateTask is not null)
        {
            var state = await AuthenticationStateTask;
            User = state.User;
        }
        if (model == null)
        {
            model ??= new();
            if (long.TryParse(User.FindFirstValue("fluxer:id"), out var userId))
            {
                var user = await guild_db.GetOrCreateUserAsync(userId);
                var settings = await db.GetOrCreateUserSettingsAsync(user);
                if (settings is not null)
                {
                    model.Global = settings.Global;
                }
            }
        }
    }

    [SupplyParameterFromForm]
    private FormModel? model { get; set; }
    private bool isLoading = false;
    private bool success = false;
    private string? errorMessage;

    private async Task Submit()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (!long.TryParse(User.FindFirstValue("fluxer:id"), out var userId))
            {
                errorMessage = "Could not resolve user ID.";
                return;
            }

            await db.UpdateUserSettings(userId, model.Global);
            success = true;
            _ = Task.Delay(3000).ContinueWith(_ =>
        {
            success = false;
            InvokeAsync(StateHasChanged);
        });
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    public class FormModel
    {
        
        public bool Global { get; set; }
    }
}


@if (success)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        <strong>Saved!</strong> Your profile settings have been updated.
        <button type="button" class="btn-close" @onclick="() => success = false" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        <strong>Error!</strong> @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
    </div>
}

<EditForm Model="model" OnValidSubmit="Submit" FormName="Starship2">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group mt-3">
        <InputCheckbox @bind-Value="model!.Global" class="form-check-input" id="globalCheck" />
        <label class="form-label" for="globalCheck">Show rank on global leaderboards</label>
    </div>
    <button type="submit" class="btn btn-primary" disabled="@isLoading">
        @(isLoading ? "Saving..." : "Save")
    </button>
</EditForm>