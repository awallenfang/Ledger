@page "/profile"
@attribute [Authorize]
@rendermode InteractiveServer
@using Database
@using Fluxify.Dto.OAuth2
@using Fluxify.Rest
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Configuration.UserSecrets
@inject LeaderboardDbService db
@inject GuildDbService guild_db
@inject Bot bot
<PageTitle>Profile Settings</PageTitle>
<h3>Profile Settings</h3>


@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }
    public OAuth2MeResponse? Me { get; set; }
    public List<TrackedGuild> trackedGuilds = new List<TrackedGuild>();

    protected override async Task OnInitializedAsync()
    {
        model ??= new();
    
        try
        {
            var authState = await AuthenticationStateTask!;
            var claimsUser = authState.User;

            if (authState.User.Identity?.IsAuthenticated != true)
            {
                return;
            }

            var userIdString = claimsUser.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!long.TryParse(userIdString, out long userId))
            {
                return;
            }
            var dbUser = await guild_db.GetOrCreateUserAsync(userId);
            var settings = await db.GetOrCreateUserSettingsAsync(dbUser);
        
            if (settings is not null)
            {
                model.Global = settings.Global;
            }
            var userGuildSettings = await db.GetAllGuildUserSettings(userId);
            foreach (var userSettings in userGuildSettings) {
                var guild = await bot.Rest.Guilds[userSettings.User.Guild.GuildId].GetAsync();
                var dbGuild = await guild_db.GetOrCreateGuildAsync(userSettings.User.Guild.GuildId);
                var guildSettings = await db.GetOrCreateSettingsAsync(dbGuild);

                var guildUser = await guild_db.GetOrCreateGuildUserAsync(dbGuild, dbUser);
                var guildRank = await db.GetOrCreateUserRankAsync(guildUser);
                var position = await db.GetGuildRankAsync(guildRank);
                
                trackedGuilds.Add(
                    new TrackedGuild {
                        ID=userSettings.User.Guild.GuildId,
                        Active=userSettings.Active,
                        Leaderboard=userSettings.Leaderboard,
                        Name=guild.Name,
                        IconURL=$"https://fluxerusercontent.com/icons/{guild.Id}/{guild.IconHash}.webp",
                        Exp=guildRank.Exp,
                        Level=guildRank.GetLevel(guildSettings),
                        Position=position
                    }
                );
            }

            model.Guilds.Clear();
            model.Guilds = trackedGuilds;
        }
        catch (Fluxify.Rest.RestApiException ex)
        {
            errorMessage = "Could not load profile from Fluxify. Are you logged in?";
        }
    }

    [SupplyParameterFromForm]
    private FormModel? model { get; set; }
    private bool isLoading = false;
    private bool success = false;
    private string? errorMessage;

    private async Task Submit()
    {
        if (model == null)
        {
            throw new InvalidOperationException("model cannot be null during submit");
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var authState = await AuthenticationStateTask!;
            var claimsUser = authState.User;

            if (authState.User.Identity?.IsAuthenticated == true)
            {
                var userIdString = claimsUser.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                if (long.TryParse(userIdString, out long userId))
                {
                    await db.UpdateUserSettings(userId, model!.Global);
                    foreach (var guild in model.Guilds)
                    {
                        // Assuming you have a method to update specific guild settings
                        await db.UpdateGuildUserSettings(userId, guild.ID, guild.Active, guild.Leaderboard);
                    }
                    _ = ShowSuccessMessage();   
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowSuccessMessage(int time = 3000) {
        success = true;
        await Task.Delay(time);
        success = false;

        await InvokeAsync(StateHasChanged);       
    }

    public class FormModel
    {
        
        public bool Global { get; set; }
        public List<TrackedGuild> Guilds { get; set; } = new();
    }

    public class TrackedGuild
    {
        public string Name { get; set; }
        public string IconURL { get; set; }
        public bool Active { get; set; }
        public bool Leaderboard { get; set; }
        public long ID {get; set; }
        public long Level { get; set; }
        public long Position { get; set; }
        public long Exp { get; set; }
    }
}


@if (success)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        <strong>Saved!</strong> Your profile settings have been updated.
        <button type="button" class="btn-close" @onclick="() => success = false" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        <strong>Error!</strong> @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
    </div>
}
@if (model == null)
{
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p><em>Loading profile...</em></p>
}
else
{
    <EditForm Model="model" OnValidSubmit="Submit" FormName="Starship2">
        <DataAnnotationsValidator />
        <h4>Tracked Guilds</h4>
    @foreach (var guild in model.Guilds)
    {
        <div class="card w-100 mb-2"> 
            <h5 class="card-header">
                <img class="rounded me-1" src="@guild.IconURL" width=30 height=30>
                @guild.Name
                <div class="float-end">#@guild.Position, Level: @guild.Level</div>
            </h5>
            <div class="card-body">
                <div class="form-check">
                    <InputCheckbox @bind-Value="guild.Active" class="form-check-input" id="@($"check-{guild.ID}-active")" />
                    <label class="form-check-label" for="@($"check-{guild.ID}-active")">Tracking Exp</label>
                </div> 
                <div class="form-check">
                    <InputCheckbox @bind-Value="guild.Leaderboard" class="form-check-input" id="@($"check-{guild.ID}-leaderboard")" />
                    <label class="form-check-label" for="@($"check-{guild.ID}-leaderboard")">Show on guild leaderboard</label>
                </div>
            </div>
        </div>
    }
    <hr />
        <ValidationSummary />
        <h4>General Settings</h4>
        <div class="form-group mt-3">
            <InputCheckbox @bind-Value="model!.Global" class="form-check-input" id="globalCheck" />
            <label class="form-label" for="globalCheck">Show rank on global leaderboards</label>
        </div>
        <button type="submit" class="btn btn-primary text-white" disabled="@isLoading">
            @(isLoading ? "Saving..." : "Save")
        </button>
    </EditForm>
}